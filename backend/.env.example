# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://johndoe:mypassword123@cluster0.abcde.mongodb.net/notary?retryWrites=true&w=majority

# JWT secret — use a long random string
JWT_SECRET=your_long_random_secret_here

# Port the backend listens on (Render sets this automatically)
PORT=5001

# Environment
NODE_ENV=production

# Your Vercel frontend URL (no trailing slash)
# e.g. https://notary-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
