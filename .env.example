# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://johndoe:mypassword123@cluster0.abcde.mongodb.net/notary?retryWrites=true&w=majority

# JWT secret key - use any long random string, keep it secret
JWT_SECRET=s3cr3tK3y!NotaryApp2025_changeMeToSomethingRandom

# Port the backend server runs on
PORT=5001

# Environment: development | production
NODE_ENV=development
